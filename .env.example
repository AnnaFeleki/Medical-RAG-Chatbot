# Provider: "ollama" (free, local, default) or "openai"
LLM_PROVIDER=ollama

# Only needed when LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here

# Optional Ollama model overrides
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# Optional: drop retrieved chunks below this relevance (0-1). 0 = keep all top-k.
# MIN_RELEVANCE=0.0
